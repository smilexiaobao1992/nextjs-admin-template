# Local runtime connection. For production, create a least-privilege role as
# documented in README and use the Supabase transaction pooler URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/admin_template

# Direct/owner connection used only by Drizzle migrations in local development
# and CI. Do not expose it to browser code or use it for runtime queries.
DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5432/admin_template

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# Optional, comma-separated. Add only when a separate frontend must call auth.
# BETTER_AUTH_TRUSTED_ORIGINS=https://admin.example.com
